-- Ищем любую периферию, в названии которой есть "substation"
local type = "gtceu:power_substation"
local s = peripheral.find(type)

if not s then
    print("Error: Substation not found!")
    print("Available peripherals:")
    -- Если не нашли, выведем список всего, что подключено к ПК
    for _, name in pairs(peripheral.getNames()) do
        print("- " .. name .. " (" .. peripheral.getType(name) .. ")")
    end
    return
end

print("Found: " .. type)
print("--- AVAILABLE METHODS ---")
-- Выводим все функции, которые можно вызвать
for k, v in pairs(s) do
    if type(v) == "function" then
        print(k)
    end
end
